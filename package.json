{
  "name": "my-travel-iq",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 execute my-travel-iq-db --local --file schemas/schema.sql",
    "db:migrate:remote": "wrangler d1 execute my-travel-iq-db --remote --file schemas/schema.sql"
  },
  "dependencies": {
    "hono": "^4.7.0"
  },
  "devDependencies": {
    "wrangler": "^4.0.0"
  }
}
